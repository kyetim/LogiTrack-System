# ==============================================
# LOGITRACK - ENVIRONMENT VARIABLES (EXAMPLE)
# ==============================================
# Copy this file to .env and fill in your actual values

# -----------------
# APPLICATION
# -----------------
NODE_ENV=development
PORT=3000
APP_NAME=LogiTrack

# -----------------
# DATABASE (PostgreSQL + PostGIS)
# -----------------
DATABASE_URL=postgresql://logitrack_user:logitrack_password@localhost:5432/logitrack_db?schema=public

# Individual PostgreSQL credentials (for direct connections if needed)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=logitrack_user
POSTGRES_PASSWORD=logitrack_password
POSTGRES_DB=logitrack_db

# -----------------
# REDIS (Cache & Queue)
# -----------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=logitrack_redis_password
REDIS_URL=redis://:logitrack_redis_password@localhost:6379

# -----------------
# JWT AUTHENTICATION
# -----------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-this
JWT_REFRESH_EXPIRATION=7d

# -----------------
# CORS SETTINGS
# -----------------
CORS_ORIGIN=http://localhost:3001,http://localhost:19006
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:19006

# -----------------
# FILE UPLOAD (AWS S3 or Local Storage)
# -----------------
UPLOAD_DESTINATION=local
# For local storage
UPLOAD_PATH=./uploads

# For AWS S3 (uncomment when ready)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=logitrack-uploads

# -----------------
# WEBSOCKET (Socket.io)
# -----------------
WEBSOCKET_PORT=3001
WEBSOCKET_CORS_ORIGIN=*

# -----------------
# RATE LIMITING
# -----------------
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# -----------------
# LOGGING
# -----------------
LOG_LEVEL=debug

# -----------------
# EXTERNAL SERVICES
# -----------------
# Google Maps API (for geocoding, directions)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# SMS/Notification Service (Twilio, etc.)
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_PHONE_NUMBER=+1234567890

# -----------------
# BULLMQ (Job Queue)
# -----------------
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=logitrack_redis_password
